# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENAI_API_KEY: Optional fallback for chat responses when Gemini fails.
OPENAI_API_KEY="MY_CHATGPT_API_KEY"

# GITHUB_TOKEN: Optional GitHub Models token for primary chat inference.
GITHUB_TOKEN="MY_GITHUB_MODELS_TOKEN"

# GITHUB_MODELS_ENDPOINT: Optional override for GitHub Models inference endpoint.
GITHUB_MODELS_ENDPOINT="https://models.github.ai/inference"

# GITHUB_MODELS_MODEL: Optional override for the GitHub Models chat model.
GITHUB_MODELS_MODEL="openai/gpt-4o-mini"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MONGODB_URI: Connection string for MongoDB (optional, falls back gracefully to local stub in express if missing)
MONGODB_URI="mongodb://127.0.0.1:27017/compute_infra"

# MONGODB_DB_NAME: Optional database name override.
MONGODB_DB_NAME="compute_infra"

# SOLANA_RPC_URL: Optional Solana RPC override.
SOLANA_RPC_URL="https://api.devnet.solana.com"

# SOLANA_PRIVATE_KEY: Optional base58 Solana secret key for live devnet withdrawals.
SOLANA_PRIVATE_KEY="MY_BASE58_SOLANA_PRIVATE_KEY"
